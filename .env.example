# ============ Auth ============
# Password seed per utenti iniziali (Marco, Paolo, Chiara). Cambiare al primo login.
DEFAULT_PASSWORD=archiva2026

# Path volume Railway dove vive users.json (in locale: ./data)
RAILWAY_VOLUME_MOUNT_PATH=./data

# ============ Jira Service Management ============
JIRA_BASE_URL=https://archivagroup.atlassian.net
JIRA_EMAIL=service-account@archivagroup.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY_TC=TC
JIRA_PROJECT_KEY_HDX=HDX

# ID custom field — DA VERIFICARE sull'istanza JSM Archiva (vedi ToDoList "Punti aperti")
# Esempio: customfield_10042
JIRA_FIELD_TICKET_SPOCCATO=customfield_11787
JIRA_FIELD_IN_ESCALATION=customfield_12384
# Custom field 'Customer name picking' (option/select) — usato per la colonna Cliente
JIRA_FIELD_CUSTOMER_NAME=customfield_12159

# Finestra temporale (formato YYYY/MM/DD)
JIRA_DATE_FROM=2026/01/01

# Polling backend (secondi). Default 600 = 10 minuti
POLL_INTERVAL_SECONDS=600

# Blocklist account bot/automation Jira (csv di accountId o displayName)
JIRA_BOT_BLOCKLIST=

# Domini email considerati "interni Archiva" per il calcolo reporter interno (csv)
ARCHIVA_INTERNAL_DOMAINS=archivagroup.com,archiva.it

# ============ Server ============
PORT=8000
